#!/usr/bin/env bash
# Sync repo docs/ -> Outline collection "Sortibox — Desarrollo" (read-only mirror).
# The repo is canonical (see CLAUDE.md / ADR Z.8); this pushes one-way to Outline.
#
# Usage:
#   scripts/outline-sync.sh                      # sync every mapped file
#   scripts/outline-sync.sh docs/glosario.md ... # sync specific files
#
# Auth: outline-cli reads OUTLINE_API_KEY / OUTLINE_BASE_URL env vars,
# or ~/.outline-skills/config.json locally.
set -euo pipefail
cd "$(dirname "$0")/.."

MAP=scripts/outline-map.json
CLI=${OUTLINE_CLI:-outline-cli}

if [ $# -gt 0 ]; then
  files=("$@")
else
  while IFS= read -r line; do files+=("$line"); done < <(python3 -c "import json; print('\n'.join(json.load(open('$MAP'))))")
fi

synced=0
for f in "${files[@]}"; do
  id=$(python3 -c "import json,sys; print(json.load(open('$MAP')).get(sys.argv[1], ''))" "$f")
  if [ -z "$id" ]; then
    echo "skip (not mapped): $f"
    continue
  fi
  if [ ! -f "$f" ]; then
    echo "skip (missing on disk): $f"
    continue
  fi
  # Sin sufijo: el mktemp de BSD/macOS exige que las X vayan al final del template
  tmp=$(mktemp "${TMPDIR:-/tmp}/outline-sync.XXXXXX")
  python3 - "$f" > "$tmp" <<'PY'
import re, sys
path = sys.argv[1]
raw = open(path, encoding="utf-8").read()
m = re.match(r"^---\n.*?\n---\n\s*", raw, flags=re.DOTALL)
body = raw[m.end():] if m else raw
banner = ("> ⚠️ **Mirror de solo lectura.** La fuente canónica vive en el repositorio "
          f"GitHub (`{path}`). Los cambios se hacen ahí vía Pull Request y se "
          "sincronizan aquí automáticamente.\n\n")
sys.stdout.write(banner + body)
PY
  "$CLI" documents update --id "$id" --text-file "$tmp" >/dev/null
  rm -f "$tmp"
  synced=$((synced + 1))
  echo "synced: $f"
done
echo "done: $synced file(s) synced"
